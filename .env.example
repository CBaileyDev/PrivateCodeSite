# PrivateCode site — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# Everything except the public app URL is optional: the site builds and runs
# without any of these, degrading gracefully (no checkout/email/db).

# ──────────────────────────────────────────────────────────────────────────
# Core
# ──────────────────────────────────────────────────────────────────────────
# Canonical, externally reachable origin (no trailing slash).
APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Strong random pepper mixed into license-key hashing.
# Generate: `openssl rand -hex 32`. REQUIRED in production.
LICENSE_HASH_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# Database — Supabase Postgres (use the connection string for the
# transaction pooler; the app sets prepare:false for pgbouncer).
# ──────────────────────────────────────────────────────────────────────────
DATABASE_URL=

# ──────────────────────────────────────────────────────────────────────────
# Supabase Auth + Storage (customer portal)
# ──────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Bypasses RLS — never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# ──────────────────────────────────────────────────────────────────────────
# Payments — Lemon Squeezy
# ──────────────────────────────────────────────────────────────────────────
LEMONSQUEEZY_API_KEY=
LEMONSQUEEZY_STORE_ID=
LEMONSQUEEZY_VARIANT_ID=
# Signing secret configured on the webhook in the Lemon Squeezy dashboard.
LEMONSQUEEZY_WEBHOOK_SECRET=

# ──────────────────────────────────────────────────────────────────────────
# Email — Resend
# ──────────────────────────────────────────────────────────────────────────
RESEND_API_KEY=
EMAIL_FROM="PrivateCode <noreply@privatecode.dev>"
SUPPORT_EMAIL=support@privatecode.dev

# ──────────────────────────────────────────────────────────────────────────
# Rate limiting — Upstash Redis (optional; allows all when unset)
# ──────────────────────────────────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ──────────────────────────────────────────────────────────────────────────
# Admin (optional) — shared secret protecting any admin surface
# ──────────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=
